# Domain to serve DNS records under.
# Machines in your tailnet will be reachable as <hostname>.DOMAIN
DOMAIN=internal.example.com

# Port CoreDNS listens on (TCP and UDP)
DNS_PORT=53

# Path to the Tailscale daemon socket on the host
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock

# DNS cache TTL in seconds
CACHE_TTL=30

# Health check endpoint port
HEALTH_PORT=8080

# Readiness check endpoint port
READY_PORT=8181
